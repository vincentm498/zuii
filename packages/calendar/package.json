{
  "name": "@zuii/calendar",
  "version": "0.2.0-beta.2",
  "type": "module",
  "description": "Composants Calendar et Reservation pour zuii",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./symfony": "./src/symfony/calendar_controller.ts",
    "./style": "./dist/style/calendar.css"
  },
  "scripts": {
    "build": "pnpm build:js && pnpm build:css && pnpm build:css:min",
    "build:css": "sass src/style/index.scss dist/style/calendar.css --load-path=node_modules --silence-deprecation=import",
    "build:css:min": "sass src/style/index.scss dist/style/calendar.min.css --style=compressed --load-path=node_modules --silence-deprecation=import",
    "build:js": "tsup",
    "dev": "pnpm build:js && pnpm build:css && tsup --watch"
  },
  "dependencies": {
    "choices.js": "^11.1.0",
    "date-fns": "^4.1.0",
    "@zuii/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "zuii",
    "calendar",
    "reservation",
    "booking"
  ],
  "author": "Vincent Moreau",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
