{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@zuii/core/*": ["packages/core/src/*"],
      "@zuii/cookie-consent": ["packages/cookie-consent/src/js/cookie-consent.ts"],
      "@zuii/cookie-consent/react": ["packages/cookie-consent/src/react/index.tsx"],
      "@zuii/cookie-consent/style": ["packages/cookie-consent/src/style/index.scss"],
      "@core/*": ["packages/core/src/styles/*"]
    },


    /* JSX */
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "playground.tsx", "packages"]
}
